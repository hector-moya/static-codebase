<div class="card mb-3{% if comment.deletedAt is not null %} border-danger{% endif %}"
     {% if comment.deletedAt is not null %}style="opacity: 0.5;"{% endif %}>
    <div class="card-header">
        <div class="row align-items-center">
            <div class="col-6">
                {{ comment.name }}
                {% if comment.deletedAt is not null %}
                    <span class="badge badge-danger ml-2">Deleted</span>
                {% endif %}
            </div>
            <div class="col-6 text-right">
                {% if show_link is defined and show_link %}
                    <a href="{{ path('comment_view', {id: comment.id}) }}" class="mr-2">View comment</a>
                {% endif %}
                <a href="{{ path('comment_edit', {id: comment.id}) }}" class="btn btn-sm btn-outline-secondary mr-1">Edit</a>
                <form method="post" action="{{ path('comment_delete', {id: comment.id}) }}" class="d-inline">
                    <button type="submit" class="btn btn-sm btn-outline-danger"
                            onclick="return confirm('Delete this comment?')">Delete</button>
                </form>
            </div>
        </div>
    </div>
    <div class="card-body">
        <blockquote class="blockquote mb-0">
            <p>{{ comment.comment }}</p>
            <footer class="blockquote-footer mb-3">
                {{ comment.createdAt|date('M j, Y') }}
                {% if comment.updatedAt|date('U') != comment.createdAt|date('U') %}
                    &middot; <em>Edited {{ comment.updatedAt|date('M j, Y') }}</em>
                {% endif %}

                {% if show_link is defined and show_link %}
                | <a href="#">{{ comment.replies|length }} Replies</a>
                {% endif %}
            </footer>
        </blockquote>
    </div>
</div>
