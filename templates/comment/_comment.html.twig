<div class="card mb-3">
    <div class="card-header">
        <div class="row">
            <div class="col-8">
                {{ comment.name }}
            </div>
            <div class="text-right col-4">
            {% if show_link is defined and show_link %}
                <a href="{{ path('comment_view', {id: comment.id}) }}">
                    View comment
                </a>
            {% endif %}
            </div>
        </div>
    </div>
    <div class="card-body">
        <blockquote class="blockquote mb-0">
            <p>{{ comment.comment }}</p>

            <footer class="blockquote-footer mb-3">
                {{ comment.createdAt|date('M j, Y') }} | <a href="#">{{ comment.replies|length }} - Replies</a>
            </footer>
        </blockquote>
    </div>
</div>
