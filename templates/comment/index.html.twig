{% extends 'base.html.twig' %}

{% block body_content %}
    <div class="row">
        <div class="col-md-12">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="mb-0">Recent Comments</h4>
                {% if show_deleted %}
                    <a href="{{ path('homepage') }}" class="btn btn-sm btn-secondary">Hide Deleted</a>
                {% else %}
                    <a href="{{ path('homepage', {show_deleted: 1}) }}" class="btn btn-sm btn-outline-secondary">Show Deleted</a>
                {% endif %}
            </div>

            {% for parentComment in pagination %}
                {{ include('comment/_comment.html.twig', { comment: parentComment, show_link: true }, with_context = false) }}
            {% endfor %}

            {{ knp_pagination_render(pagination) }}

            <hr/>

            <h4 class="mb-3">Add a comment</h4>

            {{ form_start(form) }}
            {{ include('comment/_comment_form.html.twig') }}
            <button class="btn btn-primary btn-lg btn-block" type="submit">Add Comment</button>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock body_content %}
